# Copia este archivo como .env y completa los valores antes de ejecutar la aplicación.

# Clave secreta para firmar JWT — cambia este valor en producción
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_larga

# Tiempo de vida del token JWT en minutos (default: 60)
JWT_TTL_MINUTES=60

# Clave de FRED (opcional — si no está, /api/v1/macro usa yfinance como fallback).
# Solicita una gratis en: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
