# .env.example — copia este archivo como .env y completa los valores reales.
# El .env NO debe commitearse (ya está incluido en .gitignore).

# ── Autenticación JWT ────────────────────────────────────────
# Genera una clave aleatoria larga, por ejemplo con:  openssl rand -hex 32
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_larga_en_produccion
JWT_TTL_MINUTES=60

# ── Persistencia (SQLAlchemy / SQLite) ───────────────────────
# La ruta relativa funciona si arrancas el backend desde la raiz del repo.
# Si lo arrancas desde otra carpeta usa la ruta absoluta.
DATABASE_URL=sqlite:///./data/risklab_users.db

# ── Portafolio del análisis ──────────────────────────────────
PORTFOLIO_TICKERS=NU,AMZN,SONY,XOM,WPM
BENCHMARK_TICKER=^GSPC
RISK_FREE_RATE_DEFAULT=0.04

# ── APIs externas ────────────────────────────────────────────
# Obtené tu key gratis (toma 2 min): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
YFINANCE_CACHE_TTL_HOURS=24

# ── Machine Learning ─────────────────────────────────────────
ML_MODEL_PATH=api/ml/model.joblib
